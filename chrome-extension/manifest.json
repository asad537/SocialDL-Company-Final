{
  "manifest_version": 3,
  "name": "Video Saver",
  "version": "1.0",
  "description": "Download Videos from Popular Websites",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Video Saver"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "extension-logo.png",
    "48": "extension-logo.png",
    "128": "extension-logo.png"
  },
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://hdvideosaver.com/*"
  ]
}
